# ──────────────────────────────────────────────────────────────────────────────
# Nifty Trading System — Environment Variables Template (Azure VM deployment)
#
# Copy this file to .env and fill in the real values before running docker compose.
# On the VM:  chmod 600 .env   — .env is gitignored — NEVER commit real credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ── Container images (GHCR) ───────────────────────────────────────────────────
# Your GitHub username/org that owns the pushed images, and the tag to run.
GHCR_OWNER=
IMAGE_TAG=latest

# ── Database — Azure Database for PostgreSQL (Flexible Server, managed) ────────
# Full JDBC URL to the managed endpoint. sslmode=require is MANDATORY (Azure enforces TLS).
# Example:
#   jdbc:postgresql://zupptrade-pg.postgres.database.azure.com:5432/nifty_trading?sslmode=require
DB_URL=
# Flexible Server admin login (just the username — no @server suffix) and password.
DB_USERNAME=zuppadmin
DB_PASSWORD=

# ── Internal API Key ─────────────────────────────────────────────────────────
# Shared X-API-Key for agent-to-agent calls (any strong random string).
INTERNAL_API_KEY=change_me_internal_key

# ── Upstox ────────────────────────────────────────────────────────────────────
# Get from Upstox Developer Portal → Your Apps → API Key / Secret
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# Daily access token — populated automatically by upstox-auth at 08:30 AM IST.
# For first-start or manual override, paste a valid token here.
UPSTOX_ACCESS_TOKEN=

# AES-256 encryption key for the token stored in DB (32-char hex or base64 string)
TOKEN_ENCRYPTION_KEY=

# Upstox login credentials — used by upstox-auth to obtain the daily token
UPSTOX_USERNAME=
UPSTOX_PASSWORD=
UPSTOX_TOTP_SEED=         # TOTP seed (NOT the OTP — the TOTP secret from Upstox 2FA setup)
UPSTOX_REDIRECT_URI=http://localhost:8080/callback

# ── Marketaux (news sentiment — free tier 100 req/day) ───────────────────────
MARKETAUX_API_KEY=

# ── Groq (LLM commentary extraction in Agent 1) ───────────────────────────────
GROQ_API_KEY=
