# ──────────────────────────────────────────────────────────────────────────────
# Nifty Trading System — Environment Variables Template
#
# Copy this file to .env and fill in the real values before running docker compose.
# .env is gitignored — NEVER commit the .env file with real credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local Postgres credentials (used by the postgres container AND all agents)
DB_USERNAME=nifty_user
DB_PASSWORD=change_me_strong_password

# ── Internal API Key ─────────────────────────────────────────────────────────
# Shared X-API-Key for agent-to-agent calls (any secure random string)
INTERNAL_API_KEY=change_me_internal_key

# ── Upstox ────────────────────────────────────────────────────────────────────
# Get from Upstox Developer Portal → Your Apps → API Key / Secret
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# Daily access token — populated automatically by upstox-auth service at 08:30 AM IST.
# For first-start or manual override, paste a valid token here.
UPSTOX_ACCESS_TOKEN=

# AES-256 encryption key for the token stored in DB (32-character hex or base64 string)
TOKEN_ENCRYPTION_KEY=

# Upstox login credentials — used by upstox-auth to obtain the daily token
UPSTOX_USERNAME=
UPSTOX_PASSWORD=
UPSTOX_TOTP_SEED=         # TOTP seed (NOT the OTP — the TOTP secret from Upstox 2FA setup)
UPSTOX_REDIRECT_URI=http://localhost:8080/callback

# ── Marketaux (news sentiment — free tier 100 req/day) ───────────────────────
MARKETAUX_API_KEY=

# ── Groq (LLM commentary extraction in Agent 1) ───────────────────────────────
GROQ_API_KEY=
